{
  "name": "ai-slop-guardian",
  "displayName": "AI Slop Guardian",
  "description": "Pre-commit slop detection for open-source contributors.",
  "version": "0.1.0",
  "publisher": "antigravity",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-slop-guardian.analyzeCurrentFile",
        "title": "Guardian: Analyze Current File"
      }
    ],
    "configuration": {
      "title": "AI Slop Guardian",
      "properties": {
        "aiSlopGuardian.apiUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the AI Slop Guardian Analysis Engine."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.4.0"
  }
}
